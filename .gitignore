# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage
.venv/
venv/
env/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db
# Data: BRFSS processed cohorts
# - The two CC0-dedicated cohort CSVs ARE committed (see data/LICENSE),
#   matching the paper's data-availability statement.
# - Everything else under data/ stays out of the code repo.
# - Derivation trail: data/README.md + data/PROVENANCE.md.
data/*
!data/.gitkeep
!data/README.md
!data/PROVENANCE.md
!data/LICENSE
!data/cdc_brfss_diabetes_2021.csv
!data/cdc_brfss_diabetes_2015.csv

# Run artifacts:
# - logs/ holds the log + config JSON sidecar, preserved per run (audit trail).
# - outputs/ holds data + figures, overwritten each run (latest-only).
# Authoritative artifacts ARE committed for reviewer reproducibility.
# Scratch runs are auto-excluded via the _scratch_ marker.

# logs/: keep authoritative run logs + configs, ignore scratch
#logs/*
!logs/.gitkeep
!logs/run_[0-9]*.log
!logs/run_[0-9]*.json
logs/run_scratch_*

_bk/*

# outputs/: full tree committed for reviewer reproducibility (including outputs/scratch/)

# Models
*.pkl
*.joblib
*.json.gz
/_bk/
