# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage
.venv/
venv/
env/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Data: BRFSS CSV/parquet stays out of the code repo
# - Acquisition + cleaning trail documented in data/README.md and
#   data/PROVENANCE.md (both committed)
# - Reviewer access via the journal supplement on request
data/*
!data/.gitkeep
!data/README.md
!data/PROVENANCE.md

# Run artifacts:
# - logs/ holds the log + config JSON sidecar, preserved per run (audit trail).
# - outputs/ holds data + figures, overwritten each run (latest-only).
# Authoritative artifacts ARE committed for reviewer reproducibility.
# Scratch runs are auto-excluded via the _scratch_ marker.

# logs/: keep authoritative run logs + configs, ignore scratch
logs/*
!logs/.gitkeep
!logs/run_[0-9]*.log
!logs/run_[0-9]*.json
logs/run_scratch_*

# outputs/: keep data outputs + figures of the latest run (no run_id prefix)
outputs/*
!outputs/.gitkeep
!outputs/*.csv
!outputs/*.md
!outputs/fig_*.png
!outputs/fig_*.pdf

# Models
*.pkl
*.joblib
*.json.gz
