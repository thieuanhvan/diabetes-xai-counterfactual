# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage
.venv/
venv/
env/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Data (never commit)
data/raw/
data/*.csv
data/*.parquet

# Run artifacts per §11.4 (v37): outputs/ holds log + JSON + CSV per run.
# Authoritative runs ARE committed for reviewer reproducibility.
# Scratch runs auto-excluded via _scratch_ marker.
outputs/*
!outputs/.gitkeep
!outputs/run*.log
!outputs/run*.json
!outputs/run*_cf_metrics.csv
outputs/run*_scratch_*

# Models
*.pkl
*.joblib
*.json.gz